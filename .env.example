# =============================================================================
# Django
# =============================================================================
SECRET_KEY='django-insecure-change-me-in-production'
DJANGO_SETTINGS_MODULE=llm.settings.dev
DJANGO_ENV=dev
BUILD_ENV=dev

# =============================================================================
# PostgreSQL + pgvector
# =============================================================================
DB_NAME=llm
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# =============================================================================
# Ollama — generación de texto y embeddings
#
# ollama_server : URL base del servidor Ollama.
#   - Local (mismo host que Docker): http://host.docker.internal:11434
#   - Remoto:                        http://<IP_SERVIDOR>:11434
#
# OLLAMA_MODEL  : Modelo LLM para generación de reportes y chat.
#   Ejemplos: llama3.1:latest  |  deepseek-r1:32b  |  mistral:latest
#
# OLLAMA_TIMEOUT: Segundos de espera por respuesta del LLM (default 600).
#   Incrementar si el modelo es grande y corre en CPU.
# =============================================================================
ollama_server=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:latest
OLLAMA_TIMEOUT=600

# =============================================================================
# GeoNode
# =============================================================================
GEONODE_SERVER=https://geonode.example.com

# =============================================================================
# Reportes — tipografía
#
# REPORT_FONT : Familia de fuente CSS para PDF y DOCX generados.
#   La fuente primaria debe estar instalada en el sistema (o disponible via
#   Google Fonts si el contenedor tiene acceso a internet).
#   Ejemplos: "Montserrat", sans-serif
#             "Open Sans", sans-serif
#             "Roboto", sans-serif
#             Arial, sans-serif
# =============================================================================
REPORT_FONT="Montserrat", sans-serif

# =============================================================================
# Redis / Celery
# =============================================================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
